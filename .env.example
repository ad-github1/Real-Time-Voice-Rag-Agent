# Core
VOICE_RAG_ENV=local
VOICE_RAG_DATA_DIR=data/sample_docs
VOICE_RAG_TRACE_DIR=traces
VOICE_RAG_TOP_K=4
VOICE_RAG_CHUNK_SIZE=900
VOICE_RAG_CHUNK_OVERLAP=120

# Reasoning
VOICE_RAG_REASONER=template
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
OPENAI_API_KEY=
OPENAI_MODEL=

# Voice providers
ASSEMBLYAI_API_KEY=
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Runtime
VOICE_RAG_ENABLE_TRACING=true
VOICE_RAG_MAX_CACHE_ENTRIES=128
